  "type": "audit",
  "runtime": "markdown+python",
  "description": "Identify fragile areas, lack of tests and architectural drift before launch.",
  "inputs": [
    "user_request",
    "project_context",
    "constraints"
  ],
  "outputs": [
    "structured_markdown_output",
    "validated_artifact"
  ],
  "scripts": {
    "run": "scripts/run.py",
    "validate": "scripts/validate.py"
  },
  "templates": [
    "templates/output.md",
    "templates/audit-report.template.md",
    "templates/remediation-plan.template.md"
  ],
  "examples": {
    "input": "examples/input-example.md",
    "output": "examples/output-example.md"
  },
  "concept": "concept/CONCEPT.md"
}